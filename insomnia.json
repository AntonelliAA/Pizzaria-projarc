      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"clienteCpf\": \"9001\",\n  \"enderecoEntrega\": \"Rua das Flores, 100\",\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 2 },\n    { \"produtoId\": 3, \"quantidade\": 1 }\n  ]\n}"
      }
    },
