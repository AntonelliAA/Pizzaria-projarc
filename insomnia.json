      "url": "{{ _.base_url }}/auth",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"huguinho.pato@email.com\",\n  \"senha\": \"errada\"\n}"
