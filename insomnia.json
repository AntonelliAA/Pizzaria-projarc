    {
      "_id": "req_uc1_register",
      "_type": "request",
      "parentId": "fld_uc1",
      "name": "POST /clientes — Registrar novo cliente",
      "method": "POST",
      "url": "{{ _.base_url }}/clientes",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"nome\": \"Novo Cliente\",\n  \"cpf\": \"12345\",\n  \"celular\": \"51999999999\",\n  \"endereco\": \"Rua Nova, 1\",\n  \"email\": \"novo.cliente@email.com\",\n  \"senha\": \"senha123\"\n}"
      }
    },

    {
      "_id": "req_uc2_login_9001",
      "_type": "request",
      "parentId": "fld_uc2",
      "name": "POST /auth — Login 9001 (Huguinho)",
      "method": "POST",
      "url": "{{ _.base_url }}/auth",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"huguinho.pato@email.com\",\n  \"senha\": \"senha\"\n}"
      },
      "description": "Rode esta requisição primeiro — o token retornado é referenciado automaticamente por todos os endpoints protegidos via response chaining."
    },
    {
      "_id": "req_uc2_login_9002",
      "_type": "request",
      "parentId": "fld_uc2",
      "name": "POST /auth — Login 9002 (Luizinho)",
      "method": "POST",
      "url": "{{ _.base_url }}/auth",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"zezinho.pato@email.com\",\n  \"senha\": \"senha\"\n}"
      }
    },
    {
      "_id": "req_uc2_login_invalid",
      "_type": "request",
      "parentId": "fld_uc2",
