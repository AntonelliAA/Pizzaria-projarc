      "url": "{{ _.base_url }}/pedidos/1/status",
      "headers": [
        { "name": "Authorization", "value": "Bearer {% response 'body', 'req_uc2_login_9001', 'b64::JC50b2tlbg==::46b', 'never', 60 %}" }
      ],
      "description": "Troque o ID na URL pelo pedido que você quer consultar. Ex: o id devolvido pelo UC4."
    },

    {
      "_id": "req_uc6_cancelar",
