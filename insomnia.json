      "url": "{{ _.base_url }}/pedidos/100/pagar",
      "headers": [
        { "name": "Authorization", "value": "Bearer {% response 'body', 'req_uc2_login_9001', 'b64::JC50b2tlbg==::46b', 'never', 60 %}" }
      ],
      "description": "Apenas pedidos APROVADO podem ser pagos. Após o pagamento, a cozinha/entrega simulam transições assíncronas: AGUARDANDO → PREPARACAO → PRONTO → TRANSPORTE → ENTREGUE (≈2s por etapa). Acompanhe via UC5."
    },

