      "url": "{{ _.base_url }}/pedidos/100/cancelar",
      "headers": [
        { "name": "Authorization", "value": "Bearer {% response 'body', 'req_uc2_login_9001', 'b64::JC50b2tlbg==::46b', 'never', 60 %}" }
      ],
      "description": "Funciona apenas em pedidos com status APROVADO. Substitua 100 pelo id real."
    },

    {
      "_id": "req_uc7_pagar",
      "_type": "request",
      "parentId": "fld_uc7",
      "name": "PUT /pedidos/{id}/pagar — Pagar pedido APROVADO",
